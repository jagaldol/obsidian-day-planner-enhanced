    "mdast-util-to-markdown": "^2.1.0",
    "moment-timezone": "^0.5.45",
    "node-ical": "0.18.0",
    "obsidian": "^1.6.6",
    "obsidian-daily-notes-interface": "^0.9.4",
    "overlayscrollbars-svelte": "^0.5.4",
    "svelte": "^5.55.0",
    "svelte-portal": "^2.2.1",
    "tinygesture": "^3.0.0",
    "ts-dedent": "^2.2.0",
    "ts-pattern": "^5.5.0",
