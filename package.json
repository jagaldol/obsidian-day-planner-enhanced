{
  "name": "obsidian-day-planner-enhanced",
  "version": "0.2.5",
  "description": "A day planner with an enhanced timeline UI and readable nested schedules. Based on Day Planner 0.30.0.",
  "main": "main.js",
  "scripts": {
    "build": "vite build --mode=production",
    "dev": "vite build --mode=development --watch",
    "format": "eslint --fix src tests && stylelint --fix src/**/*.svelte && prettier --write src tests scripts",
    "lint": "prettier --check src && eslint src && stylelint src/**/*.svelte && npm run typescript && svelte-check src/ && npm run test",
    "lint:scorecard": "eslint src --config .eslintrc.scorecard.cjs",
    "lint:scorecard:fix": "eslint src --config .eslintrc.scorecard.cjs --fix",
    "typescript": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "prepare": "husky install",
    "commitlint": "commitlint --edit"
  },
  "keywords": [],
  "author": "jagaldol",
  "repository": {
    "type": "git",
    "url": "https://github.com/jagaldol/obsidian-day-planner-enhanced.git"
  },
  "bugs": {
    "url": "https://github.com/jagaldol/obsidian-day-planner-enhanced/issues"
  },
  "homepage": "https://github.com/jagaldol/obsidian-day-planner-enhanced",
  "license": "MIT",
  "devDependencies": {
    "@commitlint/cli": "^19.4.1",
    "@commitlint/config-conventional": "^19.4.1",
    "@sveltejs/vite-plugin-svelte": "^4.0.0-next.6",
    "@tsconfig/svelte": "^5.0.4",
    "@types/chroma-js": "^2.4.4",
    "@types/luxon": "^3.6.2",
    "@types/mdast": "^4.0.4",
    "@types/node": "^22.5.5",
    "@types/unist": "^3.0.3",
    "@typescript-eslint/eslint-plugin": "^8.4.0",
    "@typescript-eslint/parser": "^8.6.0",
    "@vitest/coverage-v8": "^2.1.4",
    "@vitest/ui": "^2.1.4",
    "babel": "^6.23.0",
    "commander": "^14.0.3",
    "cross-env": "^7.0.3",
    "diff": "^8.0.3",
    "esbuild": "^0.23.1",
    "esbuild-plugin-replace": "^1.4.0",
    "esbuild-sass-plugin": "^3.3.1",
    "esbuild-svelte": "^0.9.0",
    "eslint": "^8.57.0",
    "eslint-import-resolver-typescript": "^3.6.3",
    "eslint-plugin-import-x": "^4.13.3",
    "eslint-plugin-svelte": "^2.43.0",
    "eslint-plugin-unused-imports": "^4.1.3",
    "husky": "^9.1.5",
    "ignore-styles": "^5.0.1",
    "jsdom": "^25.0.0",
    "jsdom-global": "^3.0.2",
    "knip": "^6.0.3",
    "moment": "^2.29.4",
    "postcss-html": "^1.7.0",
    "prettier-plugin-svelte": "latest",
    "sass": "^1.98.0",
    "simple-git": "^3.26.0",
    "stylelint": "^16.9.0",
    "stylelint-config-clean-order": "^6.1.0",
    "stylelint-config-html": "^1.1.0",
    "stylelint-config-standard": "^36.0.1",
    "svelte-check": "^4.3.2",
    "svelte-preprocess": "^6.0.3",
    "tslib": "^2.7.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.6",
    "vite-plugin-filter-replace": "^0.1.13",
    "vitest": "^2.1.3"
